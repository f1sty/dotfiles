[alias]
	a = "add"
	aa = "add --all"
	bl = "blame -w -C -C -C"
	ca = "commit --amend"
	co = "checkout"
	cv = "commit -v"
	last = "log -1 HEAD"
	last5 = "log -5 HEAD"
	pl = "pull"
	prev = "switch -"
	pu = "push"
	st = "status"
	sta = "stash --all"
	sw = "switch"
	unstage = "restore --staged"

[commit]
	gpgSign = true

[delta]
	light = false
	navigate = true

[diff]
	colormoved = "default"
	tool = "vimdiff"

[format]
	pretty = "format:%C(yellow)%h %Cblue%>(12)%ad %Cgreen%<(7)%aN%Cred%d %Creset%s"

[init]
	defaultbranch = "main"

[interactive]
	diffFilter = "/usr/bin/delta --color-only"

[merge]
	conflictstyle = "diff3"
	tool = "vimdiff"

[pager]
	blame = "/usr/bin/delta"
	diff = "/usr/bin/delta"
	log = "/usr/bin/delta"
	show = "/usr/bin/delta"

[pull]
	rebase = true

[rebase]
	updaterefs = true

[tag]
	gpgSign = true

